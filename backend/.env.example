# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://localhost:27017/fleetdash

# Redis Configuration
REDIS_URL=redis://localhost:6379
USE_REDIS_CLUSTER=false
REDIS_CLUSTER_NODES=redis://127.0.0.1:7000,redis://127.0.0.1:7001,redis://127.0.0.1:7002,redis://127.0.0.1:7003,redis://127.0.0.1:7004,redis://127.0.0.1:7005

# JWT / Security
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=24h
